# ── Base de données MySQL (XAMPP) ───────────────────────
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=
DB_NAME=concourspro

# ── Serveur ─────────────────────────────────────────────
PORT=3001
# Generez un secret fort : node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=REMPLACEZ_PAR_UN_SECRET_ALEATOIRE_LONG_ET_UNIQUE

# Origine autorisee pour le frontend (CORS)
CORS_ORIGIN=http://localhost:5173

# ── Super Admin (creation initiale uniquement) ──────────
# Utilisez un mot de passe fort. Ce compte sera utilisable tant
# que vous n'avez pas defini un Super Admin via l'interface.
SUPER_ADMIN_EMAIL=admin@votre-domaine.cm
SUPER_ADMIN_PASSWORD=CHANGEZ_MOI_MOT_DE_PASSE_FORT

# ── Anthropic API (PDF/Word import BAC) ─────────────────
# Obtenir sur https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-REMPLACEZ_PAR_VOTRE_CLE

# ── Upload ───────────────────────────────────────────────
UPLOAD_DIR=./uploads

# ── Envoi d'emails (SMTP) — utilisé pour envoyer les identifiants ────────
# aux candidats admis depuis "Gestion des Utilisateurs".
# Si ces variables sont absentes, les emails sont simplement affichés
# dans les logs (mode simulation) et les mots de passe restent visibles/
# exportables depuis l'interface.
# Exemple avec Gmail (nécessite un "mot de passe d'application") :
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=votre-adresse@gmail.com
SMTP_PASS=votre_mot_de_passe_application
SMTP_FROM=ConcoursPro <votre-adresse@gmail.com>

# URL du frontend (utilisée dans le lien d'accès envoyé par email)
FRONTEND_URL=https://votre-frontend.vercel.app
